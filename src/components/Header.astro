---
import content from "../content.json";
import Icon from "./Icons.astro";

const base = import.meta.env.BASE_URL;

const nav = [
  { label: "Services", href: "#services" },
  { label: "Why Peak", href: "#why" },
  { label: "Service Area", href: "#area" },
  { label: "Contact", href: "#contact" },
];
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-navy-100">
  <div class="mx-auto max-w-(--container-content) px-6 lg:px-8 h-24 flex items-center justify-between">
    <a href="#top" class="flex items-center gap-3 group" aria-label={content.business.name}>
      <img
        src={`${base}logo.png`}
        alt={content.business.name}
        class="h-16 sm:h-18 lg:h-20 w-auto rounded-sm"
        width="500"
        height="300"
      />
    </a>

    <nav class="hidden md:flex items-center gap-7" aria-label="Main">
      {nav.map((item) => (
        <a href={item.href} class="text-sm font-medium text-navy-700 hover:text-navy-900 transition-colors">
          {item.label}
        </a>
      ))}
      <a
        href={content.contact.phoneHref}
        class="inline-flex items-center gap-2 rounded-md bg-navy-900 hover:bg-navy-800 text-white px-4 py-2 text-sm font-semibold transition-colors"
      >
        <Icon name="phone" class="h-4 w-4" />
        {content.contact.phone}
      </a>
    </nav>

    <button
      id="nav-toggle"
      class="md:hidden p-2 -mr-2 text-navy-900"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
    >
      <Icon name="menu" class="h-6 w-6" />
    </button>
  </div>

  <div id="mobile-nav" class="md:hidden hidden border-t border-navy-100 bg-white">
    <nav class="px-6 py-4 flex flex-col gap-1" aria-label="Mobile">
      {nav.map((item) => (
        <a href={item.href} class="py-2 text-base font-medium text-navy-800 hover:text-navy-900">
          {item.label}
        </a>
      ))}
      <a
        href={content.contact.phoneHref}
        class="mt-2 inline-flex items-center justify-center gap-2 rounded-md bg-navy-900 text-white px-4 py-3 text-base font-semibold"
      >
        <Icon name="phone" class="h-5 w-5" />
        Call {content.contact.phone}
      </a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById("nav-toggle");
  const panel = document.getElementById("mobile-nav");
  if (toggle && panel) {
    toggle.addEventListener("click", () => {
      const isOpen = !panel.classList.contains("hidden");
      panel.classList.toggle("hidden");
      toggle.setAttribute("aria-expanded", String(!isOpen));
    });
    panel.querySelectorAll("a").forEach((a) => {
      a.addEventListener("click", () => {
        panel.classList.add("hidden");
        toggle.setAttribute("aria-expanded", "false");
      });
    });
  }
</script>
