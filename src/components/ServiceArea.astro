---
import content from "../content.json";
import Icon from "./Icons.astro";
---

<section id="area" class="py-20 lg:py-28 bg-navy-50">
  <div class="mx-auto max-w-(--container-content) px-6 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-5">
        <div class="text-xs uppercase tracking-[0.15em] text-amber-brand font-bold">Where we work</div>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-navy-900 tracking-tight">
          Serving {content.serviceArea}
        </h2>
        <p class="mt-5 text-lg text-navy-700 leading-relaxed">
          [SERVICE AREA INTRO — 2-3 sentences. List cities/regions covered. Mention any focus areas, e.g. "We focus on commercial accounts within X miles of downtown Santa Barbara, with regular crews running [days/week] through [areas]."]
        </p>

        <ul class="mt-8 grid grid-cols-2 gap-x-6 gap-y-3 text-sm font-medium text-navy-800">
          <li class="flex items-center gap-2"><Icon name="pin" class="h-4 w-4 text-amber-brand" />Santa Barbara</li>
          <li class="flex items-center gap-2"><Icon name="pin" class="h-4 w-4 text-amber-brand" />Montecito</li>
          <li class="flex items-center gap-2"><Icon name="pin" class="h-4 w-4 text-amber-brand" />Goleta</li>
          <li class="flex items-center gap-2"><Icon name="pin" class="h-4 w-4 text-amber-brand" />[CITY 4]</li>
          <li class="flex items-center gap-2"><Icon name="pin" class="h-4 w-4 text-amber-brand" />[CITY 5]</li>
          <li class="flex items-center gap-2"><Icon name="pin" class="h-4 w-4 text-amber-brand" />[CITY 6]</li>
        </ul>

        <a
          href="#contact"
          class="mt-8 inline-flex items-center gap-2 rounded-md bg-navy-900 hover:bg-navy-800 text-white px-5 py-3 text-sm font-semibold transition-colors"
        >
          Check if we cover your property
          <Icon name="arrow" class="h-4 w-4" />
        </a>
      </div>

      <div class="lg:col-span-7">
        {/* TODO (Kevin to confirm): currently pins the 93160 PO Box ZIP, matching the original site.
            93160 is a PO-Box-only ZIP centroid, not a place customers visit. If Kevin prefers a
            different pin (e.g. a service-area center, downtown SB, or no pin), swap the q= value:
              q=93160                 → current behavior, pin on PO Box ZIP
              q=Santa+Barbara,+CA     → pin on downtown Santa Barbara
              ll=34.43,-119.77&z=13   → no pin, just centered (replace q= entirely) */}
        <div class="relative aspect-[4/3] rounded-2xl shadow-xl shadow-navy-900/10 overflow-hidden border border-navy-100 bg-navy-50">
          <iframe
            title="Peak Lighting & Energy service area map"
            src="https://maps.google.com/maps?q=93160&z=13&t=m&output=embed"
            class="absolute inset-0 h-full w-full"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
        <a
          href="https://www.google.com/maps/place/Santa+Barbara,+CA"
          target="_blank"
          rel="noopener"
          class="mt-3 inline-flex items-center gap-1.5 text-sm font-semibold text-navy-700 hover:text-navy-900"
        >
          Open in Google Maps
          <Icon name="arrow" class="h-3.5 w-3.5" />
        </a>
      </div>
    </div>
  </div>
</section>
