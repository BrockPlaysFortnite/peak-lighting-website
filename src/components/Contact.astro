---
import content from "../content.json";
import Icon from "./Icons.astro";

const { contact } = content;
---

<section id="contact" class="py-20 lg:py-28 bg-white">
  <div class="mx-auto max-w-(--container-content) px-6 lg:px-8">
    <div class="grid lg:grid-cols-12 gap-12">
      <div class="lg:col-span-5">
        <div class="text-xs uppercase tracking-[0.15em] text-amber-brand font-bold">Get in touch</div>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-navy-900 tracking-tight">
          Let's talk about your property
        </h2>
        <p class="mt-5 text-lg text-navy-700 leading-relaxed">
          [CONTACT INTRO — e.g. "Tell us a bit about what you need. We'll respond within [24 hours] with next steps or a scheduled walkthrough."]
        </p>

        <dl class="mt-8 space-y-5">
          <div class="flex items-start gap-4">
            <div class="h-10 w-10 rounded-lg bg-navy-900 text-amber-brand grid place-items-center shrink-0">
              <Icon name="phone" class="h-5 w-5" />
            </div>
            <div>
              <dt class="text-xs uppercase tracking-wide text-navy-500 font-semibold">Phone</dt>
              <dd class="mt-0.5"><a href={contact.phoneHref} class="font-display text-xl font-semibold text-navy-900 hover:text-navy-700">{contact.phone}</a></dd>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="h-10 w-10 rounded-lg bg-navy-900 text-amber-brand grid place-items-center shrink-0">
              <Icon name="mail" class="h-5 w-5" />
            </div>
            <div>
              <dt class="text-xs uppercase tracking-wide text-navy-500 font-semibold">Email</dt>
              <dd class="mt-0.5"><a href={`mailto:${contact.email}`} class="font-display text-lg font-semibold text-navy-900 hover:text-navy-700 break-all">{contact.email}</a></dd>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="h-10 w-10 rounded-lg bg-navy-900 text-amber-brand grid place-items-center shrink-0">
              <Icon name="pin" class="h-5 w-5" />
            </div>
            <div>
              <dt class="text-xs uppercase tracking-wide text-navy-500 font-semibold">Mailing address</dt>
              <dd class="mt-0.5 text-navy-900 font-medium">{contact.addressLine1}<br />{contact.addressLine2}</dd>
            </div>
          </div>
        </dl>
      </div>

      <div class="lg:col-span-7">
        <form
          action={`mailto:${contact.email}`}
          method="POST"
          enctype="text/plain"
          class="rounded-2xl border border-navy-100 bg-navy-50/60 p-6 sm:p-8 space-y-5"
        >
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="name" class="block text-sm font-semibold text-navy-800">Name</label>
              <input id="name" name="name" type="text" required class="mt-2 w-full rounded-md border border-navy-200 bg-white px-3.5 py-2.5 text-navy-900 placeholder-navy-400 focus:border-navy-500 focus:outline-none focus:ring-2 focus:ring-navy-200" placeholder="Your name" />
            </div>
            <div>
              <label for="company" class="block text-sm font-semibold text-navy-800">Company / property</label>
              <input id="company" name="company" type="text" class="mt-2 w-full rounded-md border border-navy-200 bg-white px-3.5 py-2.5 text-navy-900 placeholder-navy-400 focus:border-navy-500 focus:outline-none focus:ring-2 focus:ring-navy-200" placeholder="Optional" />
            </div>
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label for="email" class="block text-sm font-semibold text-navy-800">Email</label>
              <input id="email" name="email" type="email" required class="mt-2 w-full rounded-md border border-navy-200 bg-white px-3.5 py-2.5 text-navy-900 placeholder-navy-400 focus:border-navy-500 focus:outline-none focus:ring-2 focus:ring-navy-200" placeholder="you@example.com" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-semibold text-navy-800">Phone</label>
              <input id="phone" name="phone" type="tel" class="mt-2 w-full rounded-md border border-navy-200 bg-white px-3.5 py-2.5 text-navy-900 placeholder-navy-400 focus:border-navy-500 focus:outline-none focus:ring-2 focus:ring-navy-200" placeholder="Optional" />
            </div>
          </div>
          <div>
            <label for="message" class="block text-sm font-semibold text-navy-800">How can we help?</label>
            <textarea id="message" name="message" rows="5" required class="mt-2 w-full rounded-md border border-navy-200 bg-white px-3.5 py-2.5 text-navy-900 placeholder-navy-400 focus:border-navy-500 focus:outline-none focus:ring-2 focus:ring-navy-200" placeholder="Tell us about your property and what you need."></textarea>
          </div>
          <button type="submit" class="inline-flex items-center justify-center gap-2 w-full sm:w-auto rounded-md bg-navy-900 hover:bg-navy-800 text-white px-6 py-3.5 text-base font-semibold transition-colors">
            Send request
            <Icon name="arrow" class="h-4 w-4" />
          </button>
          <p class="text-xs text-navy-500">We'll get back to you within one business day.</p>
        </form>
      </div>
    </div>
  </div>
</section>
