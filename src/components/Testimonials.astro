---
import content from "../content.json";

const { testimonials } = content;
---

<section id="testimonials" class="py-20 lg:py-28 bg-white">
  <div class="mx-auto max-w-(--container-content) px-6 lg:px-8">
    <div class="max-w-2xl">
      <div class="text-xs uppercase tracking-[0.15em] text-amber-brand font-bold">What clients say</div>
      <h2 class="mt-3 font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-navy-900 tracking-tight">
        Trusted by property managers across the Central Coast
      </h2>
    </div>

    <div class="mt-12 grid md:grid-cols-2 gap-6">
      {testimonials.map((t) => (
        <figure class="rounded-xl border border-navy-100 bg-navy-50 p-8">
          <svg viewBox="0 0 24 24" class="h-8 w-8 text-amber-brand" fill="currentColor" aria-hidden="true">
            <path d="M7 7h4v4H8c0 2 1 3 3 3v3c-4 0-6-2-6-6V7Zm9 0h4v4h-3c0 2 1 3 3 3v3c-4 0-6-2-6-6V7Z" />
          </svg>
          <blockquote class="mt-4 font-display text-lg text-navy-900 leading-snug">
            "{t.quote}"
          </blockquote>
          <figcaption class="mt-5 text-sm">
            <div class="font-semibold text-navy-900">{t.author}</div>
            <div class="text-navy-600">{t.role}</div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
