---
import content from "../content.json";
import Icon from "./Icons.astro";
---

<section id="top" class="relative overflow-hidden bg-gradient-to-b from-white to-navy-50">
  <div class="absolute inset-0 peak-motif opacity-60 pointer-events-none"></div>

  <div class="relative mx-auto max-w-(--container-content) px-6 lg:px-8 pt-16 lg:pt-24 pb-20 lg:pb-28">
    <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <div class="lg:col-span-7">
        <div class="inline-flex items-center gap-2 rounded-full bg-navy-100 text-navy-700 px-3 py-1 text-xs font-semibold tracking-wide uppercase">
          <span class="h-1.5 w-1.5 rounded-full bg-amber-brand"></span>
          Serving {content.serviceArea}
        </div>

        <h1 class="mt-5 font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-navy-900 leading-[1.05] tracking-tight">
          {content.business.tagline}
        </h1>

        <p class="mt-6 text-lg lg:text-xl text-navy-700 leading-relaxed max-w-2xl">
          {content.business.shortPitch}
        </p>

        <div class="mt-8 flex flex-col sm:flex-row gap-3">
          <a
            href={content.contact.phoneHref}
            class="inline-flex items-center justify-center gap-2 rounded-md bg-navy-900 hover:bg-navy-800 text-white px-6 py-3.5 text-base font-semibold transition-colors"
          >
            <Icon name="phone" class="h-5 w-5" />
            Call {content.contact.phone}
          </a>
          <a
            href="#contact"
            class="inline-flex items-center justify-center gap-2 rounded-md bg-white border border-navy-200 hover:border-navy-300 text-navy-900 px-6 py-3.5 text-base font-semibold transition-colors"
          >
            Request a quote
            <Icon name="arrow" class="h-4 w-4" />
          </a>
        </div>

        <div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-navy-600">
          <div class="flex items-center gap-2"><Icon name="check" class="h-4 w-4 text-amber-brand" />Licensed & insured</div>
          <div class="flex items-center gap-2"><Icon name="check" class="h-4 w-4 text-amber-brand" />Free written quotes</div>
          <div class="flex items-center gap-2"><Icon name="check" class="h-4 w-4 text-amber-brand" />[X+] years on the Central Coast</div>
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="relative">
          <div class="placeholder-img aspect-[4/5] rounded-2xl shadow-2xl shadow-navy-900/20">
            <div class="placeholder-label">[HERO IMAGE — commercial property exterior]</div>
          </div>
          <!-- Floating stat card -->
          <div class="absolute -bottom-6 -left-6 hidden sm:block bg-white rounded-xl shadow-xl shadow-navy-900/10 border border-navy-100 p-5 w-56">
            <div class="text-xs uppercase tracking-wide text-navy-500 font-semibold">Typical response</div>
            <div class="mt-1 font-display text-2xl font-bold text-navy-900">[24 hours]</div>
            <div class="mt-1 text-xs text-navy-600">From quote request to scheduled walkthrough.</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
