---
import content from "../content.json";
import Icon from "./Icons.astro";

const services = content.services as Array<{
  title: string;
  description: string;
  icon: "spark" | "panel" | "wrench" | "shield";
}>;
---

<section id="services" class="py-20 lg:py-28 bg-white">
  <div class="mx-auto max-w-(--container-content) px-6 lg:px-8">
    <div class="max-w-2xl">
      <div class="text-xs uppercase tracking-[0.15em] text-amber-brand font-bold">What we do</div>
      <h2 class="mt-3 font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-navy-900 tracking-tight">
        Services built for commercial properties
      </h2>
      <p class="mt-4 text-lg text-navy-700">
        [INTRO COPY — one sentence summarizing the offering, e.g. "From lighting and energy systems to general property upkeep, Peak handles it with one point of contact."]
      </p>
    </div>

    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {services.map((svc) => (
        <div class="group relative rounded-xl border border-navy-100 bg-white p-6 hover:border-navy-300 hover:shadow-lg hover:shadow-navy-900/5 transition-all">
          <div class="h-11 w-11 rounded-lg bg-navy-900 text-amber-brand grid place-items-center">
            <Icon name={svc.icon} class="h-6 w-6" />
          </div>
          <h3 class="mt-5 font-display text-lg font-semibold text-navy-900">{svc.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-navy-700">{svc.description}</p>
          <div class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold text-navy-800 group-hover:text-navy-900">
            Learn more
            <Icon name="arrow" class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" />
          </div>
        </div>
      ))}
    </div>

    <div class="mt-10 text-sm text-navy-600">
      Don't see what you need? <a href="#contact" class="font-semibold text-navy-900 underline underline-offset-4 decoration-amber-brand decoration-2 hover:decoration-amber-brand-soft">Ask us</a> — we likely do that too.
    </div>
  </div>
</section>
